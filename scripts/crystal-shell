#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# crystal-shell — Wayland session entry point
# Installed to /usr/bin/crystal-shell
# Launched by the display manager via /usr/share/wayland-sessions/crystal-shell.desktop
# ─────────────────────────────────────────────────────────────────────────────

# Wayland environment
export GDK_BACKEND=wayland,x11
export XDG_SESSION_TYPE=wayland
export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT=auto
export OZONE_PLATFORM=wayland
export QT_QPA_PLATFORMTHEME=qt6ct
export CLUTTER_BACKEND=wayland

# GObject Introspection
export GI_TYPELIB_PATH="/usr/lib/girepository-1.0:/usr/local/lib/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"
export LD_LIBRARY_PATH="/usr/lib:/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

exec uwsm start -- hyprland -c /usr/share/crystal-shell/config/hypr/hyprland.conf
