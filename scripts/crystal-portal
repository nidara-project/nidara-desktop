#!/usr/bin/env -S gjs -m
// ─────────────────────────────────────────────────────────────────────────────
// crystal-portal — Crystal Shell's xdg-desktop-portal Settings backend
// Installed to /usr/bin/crystal-portal, D-Bus-activated as
// org.freedesktop.impl.portal.desktop.crystal (see the .portal + .service
// files installed by install.sh).
//
// WHY THIS EXISTS: under Hyprland no portal backend serves
// `org.freedesktop.appearance accent-color`, so libadwaita/GNOME apps
// (Calendar, nautilus…) never see the Crystal accent — they stay on their
// default blue even though gsettings is set correctly (libadwaita reads the
// PORTAL, not gsettings, and does not fall back per-key).
//
// This backend serves EXACTLY ONE key: org.freedesktop.appearance
// accent-color, as the (ddd) RGB tuple the spec defines. Everything else
// (color-scheme, contrast) intentionally returns "not found" so the portal
// frontend falls through to the next backend in portals.conf
// (`org.freedesktop.impl.portal.Settings=crystal;gtk`) — verified against
// xdg-desktop-portal 1.20 src/settings.c: ReadAll merges ALL configured
// impls (earlier in the list wins) and Read takes the first impl that has
// the key.
//
// Source of truth: gsettings org.gnome.desktop.interface accent-color (the
// accent NAME — ThemeManager keeps it in sync with the Settings UI, both
// ways), mapped to the Crystal hex below. Live updates via SettingChanged.
// ─────────────────────────────────────────────────────────────────────────────

import Gio from "gi://Gio"
import GLib from "gi://GLib"

// KEEP IN SYNC with ui/lib/accent.ts ACCENT_HEX (single source of truth for
// the palette). Duplicated here because this daemon is a standalone GJS
// script with no access to the TS bundles.
const ACCENT_HEX = {
    blue:   "#0088FF",
    teal:   "#2190a4",
    green:  "#79B757",
    yellow: "#F3BA4B",
    orange: "#E9873A",
    red:    "#ED5F5D",
    pink:   "#E55E9C",
    purple: "#9A57A3",
    slate:  "#6f8396",
}

const APPEARANCE_NS = "org.freedesktop.appearance"
const BUS_NAME = "org.freedesktop.impl.portal.desktop.crystal"
const OBJECT_PATH = "/org/freedesktop/portal/desktop"

const IFACE_XML = `
<node>
  <interface name="org.freedesktop.impl.portal.Settings">
    <property name="version" type="u" access="read"/>
    <method name="ReadAll">
      <arg type="as" name="namespaces" direction="in"/>
      <arg type="a{sa{sv}}" name="value" direction="out"/>
    </method>
    <method name="Read">
      <arg type="s" name="namespace" direction="in"/>
      <arg type="s" name="key" direction="in"/>
      <arg type="v" name="value" direction="out"/>
    </method>
    <signal name="SettingChanged">
      <arg type="s" name="namespace"/>
      <arg type="s" name="key"/>
      <arg type="v" name="value"/>
    </signal>
  </interface>
</node>`

const interfaceSettings = new Gio.Settings({ schema_id: "org.gnome.desktop.interface" })

function accentRgbVariant() {
    const name = interfaceSettings.get_string("accent-color")
    const hex = ACCENT_HEX[name] ?? ACCENT_HEX.blue
    const r = parseInt(hex.slice(1, 3), 16) / 255
    const g = parseInt(hex.slice(3, 5), 16) / 255
    const b = parseInt(hex.slice(5, 7), 16) / 255
    return new GLib.Variant("(ddd)", [r, g, b])
}

// xdg-desktop-portal passes the requesting app's namespace patterns through;
// glob per the spec ("" or missing list = everything).
function nsMatches(patterns) {
    if (!patterns || patterns.length === 0) return true
    return patterns.some(p => p === "" || GLib.pattern_match_simple(p, APPEARANCE_NS))
}

// Async variants (manual reply): GJS's automatic return-marshalling mishandles
// a bare `v` out-arg (the reply never goes out → client timeout), so both
// methods reply explicitly with the full tuple.
class SettingsBackend {
    get version() { return 1 }

    ReadAllAsync(params, invocation) {
        const [namespaces] = params
        const dict = nsMatches(namespaces)
            ? { [APPEARANCE_NS]: { "accent-color": accentRgbVariant() } }
            : {}
        invocation.return_value(new GLib.Variant("(a{sa{sv}})", [dict]))
    }

    ReadAsync(params, invocation) {
        const [namespace, key] = params
        if (namespace === APPEARANCE_NS && key === "accent-color") {
            invocation.return_value(new GLib.Variant("(v)", [accentRgbVariant()]))
        } else {
            // Anything else: error out so the frontend falls through to the
            // next backend in portals.conf (gtk serves color-scheme/contrast).
            invocation.return_dbus_error(
                "org.freedesktop.portal.Error.NotFound",
                `crystal-portal does not serve ${namespace} ${key}`,
            )
        }
    }
}

const loop = new GLib.MainLoop(null, false)
const backend = new SettingsBackend()
const exported = Gio.DBusExportedObject.wrapJSObject(IFACE_XML, backend)

Gio.bus_own_name(
    Gio.BusType.SESSION,
    BUS_NAME,
    Gio.BusNameOwnerFlags.NONE,
    (connection) => {
        exported.export(connection, OBJECT_PATH)
        // Live updates: accent changed in Crystal Settings (or anywhere) →
        // ThemeManager syncs gsettings → we notify every portal client.
        interfaceSettings.connect("changed::accent-color", () => {
            exported.emit_signal(
                "SettingChanged",
                new GLib.Variant("(ssv)", [APPEARANCE_NS, "accent-color", accentRgbVariant()]),
            )
        })
        print(`[crystal-portal] serving ${APPEARANCE_NS} accent-color on ${BUS_NAME}`)
    },
    null,
    () => {
        printerr(`[crystal-portal] lost/failed bus name ${BUS_NAME} — exiting`)
        loop.quit()
    },
)

loop.run()
