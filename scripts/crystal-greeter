#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# crystal-greeter — Crystal Shell greeter launcher
# Installed to /usr/bin/crystal-greeter
# Called by greetd via hyprland-greeter.conf exec-once
# ─────────────────────────────────────────────────────────────────────────────

BUNDLE="/usr/share/crystal-shell/ui/greeter/build/crystal-greeter"
LOG="/tmp/crystal-greeter.log"

export GDK_BACKEND=wayland
export GI_TYPELIB_PATH="/usr/lib/girepository-1.0:/usr/local/lib/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"
export LD_LIBRARY_PATH="/usr/lib:/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export GREETD_SOCK="${GREETD_SOCK}"

if [ -x "$BUNDLE" ]; then
    cd /usr/share/crystal-shell/ui/greeter
    exec "$BUNDLE" >> "$LOG" 2>&1
fi

echo "[$(date '+%H:%M:%S')] crystal-greeter: ERROR — bundle not found at $BUNDLE" | tee -a "$LOG"
exit 1
