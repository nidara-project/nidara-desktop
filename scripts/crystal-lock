#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# crystal-lock — Crystal Shell lock screen launcher
# Installed to /usr/bin/crystal-lock
# Called by hypridle, loginctl lock-session, and Hyprland keybinds
# ─────────────────────────────────────────────────────────────────────────────

BUNDLE="/usr/share/crystal-shell/ui/lockscreen/build/crystal-lock"
LOG="/tmp/crystal-lock.log"

export GDK_BACKEND=wayland
export GI_TYPELIB_PATH="/usr/lib/girepository-1.0:/usr/local/lib/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"
export LD_LIBRARY_PATH="/usr/lib:/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LD_PRELOAD="/usr/lib/libgtk4-layer-shell.so${LD_PRELOAD:+:$LD_PRELOAD}"

# Prevent multiple instances (exclude own PID — bash names itself after the script)
SELF=$$
if pgrep -x crystal-lock | grep -qv "^${SELF}$"; then
    exit 0
fi

if [ ! -x "$BUNDLE" ]; then
    echo "[$(date '+%H:%M:%S')] crystal-lock: ERROR — bundle not found at $BUNDLE" | tee -a "$LOG"
    exit 1
fi

# Save current workspace (prefer name for named workspaces, fallback to id)
PREV_WS=$(hyprctl activeworkspace -j 2>/dev/null | jq -r 'if .name and (.name | test("^[0-9]+$") | not) then "name:" + .name else (.id | tostring) end // empty')

# Hide bar and dock, disable all keybinds, switch to dedicated lock workspace
ags request hideForLock >> "$LOG" 2>&1 || true
hyprctl dispatch 'hl.dsp.submap("lock")' >> "$LOG" 2>&1 || true
hyprctl dispatch "hl.dsp.focus({workspace='name:lockspace'})" >> "$LOG" 2>&1 || true

# Run lockscreen — blocks until app.quit() on successful auth
cd /usr/share/crystal-shell/ui/lockscreen
"$BUNDLE" >> "$LOG" 2>&1

# Restore everything after unlock
hyprctl dispatch 'hl.dsp.submap("reset")' >> "$LOG" 2>&1 || true
[ -n "$PREV_WS" ] && hyprctl dispatch "hl.dsp.focus({workspace='$PREV_WS'})" >> "$LOG" 2>&1 || true
ags request showAfterLock >> "$LOG" 2>&1 || true
