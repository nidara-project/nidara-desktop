[Desktop Entry]
Name=Nidara Settings
Comment=Configure your Nidara environment
# Note: ags request IPC is broken in GJS >= 1.88.
# Settings is opened via the dock (DockItem bypasses Exec and calls toggleSettings directly).
# This entry exists so AppService.ts can detect it as a known app.
Exec=bash -c 'notify-send "Nidara" "Open Settings from the dock or taskbar."'
Icon=preferences-system
Type=Application
Categories=Settings;DesktopSettings;
Keywords=settings;config;theme;appearance;
StartupNotify=false
