# MiDistroIA Sway Configuration
# Configuración base para el compositor Sway

# --- VARIABLES ---
set $mod Mod4
set $term foot
set $menu wofi --show drun
set $dock python3 ~/Dev/MiDistroIA/ui/dock/main_dock.py

# --- OUTPUT ---
# Configurar monitor (ajustar según tu pantalla)
# output * bg ~/Dev/MiDistroIA/assets/wallpaper.jpg fill

# --- INPUT ---
input type:keyboard {
    xkb_layout "es"
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
}

# --- APARIENCIA ---
# Sin bordes en ventanas
default_border none
default_floating_border none

# Gaps para estética minimalista
gaps inner 10
gaps outer 5

# --- AUTOSTART ---
# Lanzar nuestro Dock al iniciar
exec $dock

# --- KEYBINDINGS ---
# Cerrar ventana
bindsym $mod+q kill

# Abrir terminal
bindsym $mod+Return exec $term

# Launcher
bindsym $mod+d exec $menu

# Salir de Sway
bindsym $mod+Shift+e exec swaynag -t warning -m 'Salir de MiDistroIA?' -B 'Sí' 'swaymsg exit'

# Mover ventanas
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Down move down

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4

# Floating toggle
bindsym $mod+Shift+space floating toggle

# Fullscreen
bindsym $mod+f fullscreen toggle

# Reload config
bindsym $mod+Shift+c reload

# --- REGLAS DE VENTANAS ---
# Hacer que ciertas ventanas sean floating por defecto
for_window [app_id="ai_menu"] floating enable
for_window [title="MiDistro Dock"] floating enable

# Include additional config files
include /etc/sway/config.d/*
