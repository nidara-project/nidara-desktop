#!/usr/bin/env -S gjs -m
// ─────────────────────────────────────────────────────────────────────────────
// crystal-a11y — read-only perception of THIRD-PARTY apps for the computer-use
// layer. Installed to /usr/bin/crystal-a11y. Prints, as JSON on stdout, the
// accessibility tree of an application in the SAME flat-node shape as the
// shell's own `queryUI` (ui/shell/core/UITree.ts) — so an agent perceives a
// foreign window (Firefox, a file manager, an IDE) exactly the way it perceives
// the shell, and consumers can't tell the source changed. This is the AT-SPI2
// backend that UITree.ts always pointed at ("a future AT-SPI2 backend can fill
// the same shape for third-party apps under the computer-use layer").
//
//   crystal-a11y            → the focused application's window
//   crystal-a11y firefox    → windows of apps whose name matches "firefox"
//
// READ-ONLY by design (Phase 1). No clicks, no synthetic input, no AT-SPI
// actions are invoked — available action NAMES are merely listed, as fuel for a
// later, gated action phase. AT-SPI extents are reported in WINDOW coordinates:
// a client's SCREEN position is unreliable on Wayland, so global mapping (when
// it's ever needed) is a compositor-side concern, not ours.
//
// Plain GJS on purpose (same as crystal-portal / crystal-shell-mcp): gjs +
// gi://Atspi ship with the shell, no Node runtime, no npm deps on installed
// systems.
//
// Governance: Settings → AI → allowComputerUse (ai.json). This is the ONLY gate
// that defaults OFF — reading another app's content is privacy-sensitive (≈ the
// screenshot gate) and reaches outside the shell's own surface. Consent layer,
// not a security boundary: any local process can already read the a11y bus.
// ─────────────────────────────────────────────────────────────────────────────

import Atspi from "gi://Atspi"
import GLib from "gi://GLib"

const AI_JSON = `${GLib.get_user_config_dir()}/crystal-shell/ai.json`
const MAX_NODES = 500       // mirrors UITree.ts
const MAX_DEPTH = 40        // a11y trees can be deep; guard runaway recursion
const DEADLINE_MS = 4000    // soft budget: bail out of a slow/huge tree gracefully

// ── gate ─────────────────────────────────────────────────────────────────────
// Defaults OFF: absent/garbled ai.json → disabled (opposite of allowMcp).
function computerUseEnabled() {
    try {
        if (!GLib.file_test(AI_JSON, GLib.FileTest.EXISTS)) return false
        const [ok, bytes] = GLib.file_get_contents(AI_JSON)
        if (!ok) return false
        return JSON.parse(new TextDecoder().decode(bytes)).allowComputerUse === true
    } catch {
        return false
    }
}

function emit(obj) {
    print(JSON.stringify(obj, null, 2))
}

function safe(fn, fallback) {
    try {
        const v = fn()
        return v == null ? fallback : v
    } catch {
        return fallback
    }
}

// ── state naming ───────────────────────────────────────────────────────────────
// A curated set of states worth surfacing, checked via StateSet.contains so we
// never depend on enumerating the full StateType space.
const STATE_CHECKS = [
    ["focused", Atspi.StateType.FOCUSED],
    ["focusable", Atspi.StateType.FOCUSABLE],
    ["editable", Atspi.StateType.EDITABLE],
    ["selected", Atspi.StateType.SELECTED],
    ["checked", Atspi.StateType.CHECKED],
    ["expanded", Atspi.StateType.EXPANDED],
    ["active", Atspi.StateType.ACTIVE],
    ["sensitive", Atspi.StateType.SENSITIVE],
    ["showing", Atspi.StateType.SHOWING],
]

function statesOf(acc) {
    const set = safe(() => acc.get_state_set(), null)
    if (!set) return []
    const out = []
    for (const [name, st] of STATE_CHECKS)
        if (safe(() => set.contains(st), false)) out.push(name)
    return out
}

function isShowing(acc) {
    const set = safe(() => acc.get_state_set(), null)
    return !!set && safe(() => set.contains(Atspi.StateType.SHOWING), false)
}

function isActive(acc) {
    const set = safe(() => acc.get_state_set(), null)
    return !!set && safe(() => set.contains(Atspi.StateType.ACTIVE), false)
}

// ── per-node extraction ────────────────────────────────────────────────────────

// Roles whose mere presence carries signal even without a name (mirrors UITree's
// INTERACTIVE set, in AT-SPI role-name terms).
const INTERACTIVE_ROLES = new Set([
    "push button", "toggle button", "check box", "radio button", "radio menu item",
    "check menu item", "menu item", "link", "entry", "text", "password text",
    "combo box", "list item", "slider", "spin button", "page tab", "tab",
    "table cell", "tree item", "switch",
])

function textOf(acc, roleName) {
    // Never leak a secret: AT-SPI exposes masked fields as role "password text".
    if (roleName === "password text") return "‹redacted›"
    const iface = safe(() => acc.get_text_iface(), null)
    if (!iface) return null
    // AtspiText is the same boxed object as the Accessible, so `iface.get_text`
    // resolves to Accessible's own 0-arg get_text — call the Text interface
    // method explicitly to reach the (start, end) overload.
    const n = safe(() => Atspi.Text.prototype.get_character_count.call(iface), 0)
    if (!n) return null
    const t = safe(() => Atspi.Text.prototype.get_text.call(iface, 0, Math.min(n, 2000)), null)
    return typeof t === "string" && t.length ? t : null
}

function actionsOf(acc) {
    const iface = safe(() => acc.get_action_iface(), null)
    if (!iface) return []
    const n = safe(() => iface.get_n_actions(), 0)
    const out = []
    for (let i = 0; i < n; i++) {
        const name = safe(() => iface.get_action_name(i), null)
        if (name) out.push(name)
    }
    return out
}

const ACCEL_KEY = /^(F\d+|Enter|Return|Delete|Tab|Escape|Backspace|Space|Insert|Home|End|Page_Up|Page_Down|Up|Down|Left|Right)$/

// Keyboard accelerators of a control's actions (AT-SPI key bindings) — e.g.
// ["Control+X"]. Often the ONLY semantic handle on a label-less control: GTK4
// popover-menu items expose no accessible name/text, but DO carry their
// shortcut, so Ctrl+X ⇒ Cut, F2 ⇒ Rename, Delete ⇒ Move to Trash, etc.
function shortcutsOf(acc) {
    const iface = safe(() => acc.get_action_iface(), null)
    if (!iface) return []
    const n = safe(() => iface.get_n_actions(), 0)
    const out = []
    for (let i = 0; i < n; i++) {
        // AtspiKeyBinding strings look like "T;;Control+X" (mnemonic;;accelerator).
        const kb = safe(() => iface.get_key_binding(i), "") || ""
        const segs = kb.split(";").map(s => s.trim()).filter(Boolean)
        if (!segs.length) continue
        // Prefer the real accelerator (has a modifier or is a named key) over the
        // bare mnemonic letter.
        const pick = segs.find(s => /(Control|Alt|Shift|Super|Meta)\+/.test(s)) ||
            segs.find(s => ACCEL_KEY.test(s)) || segs[0]
        if (pick && !out.includes(pick)) out.push(pick)
    }
    return out
}

function boundsOf(acc) {
    const iface = safe(() => acc.get_component_iface(), null)
    if (!iface) return { w: 0, h: 0 }
    // WINDOW coords: SCREEN extents are unreliable on Wayland (see header).
    const r = safe(() => iface.get_extents(Atspi.CoordType.WINDOW), null)
    if (!r) return { w: 0, h: 0 }
    return { x: Math.round(r.x), y: Math.round(r.y), w: Math.round(r.width), h: Math.round(r.height) }
}

function nodeOf(acc, windowLabel, path) {
    const roleName = safe(() => acc.get_role_name(), "?")
    const name = safe(() => acc.get_name(), "") || null
    const actions = actionsOf(acc)
    const shortcuts = shortcutsOf(acc)
    return {
        window: windowLabel,
        type: roleName,            // AT-SPI role name — analogous to UITree's GType
        id: name,                  // accessible name — analogous to UITree's get_name()
        role: roleName,
        text: textOf(acc, roleName),
        states: statesOf(acc),
        actions,
        // Only when present — keeps the common (no-shortcut) node lean.
        ...(shortcuts.length ? { shortcuts } : {}),
        visible: isShowing(acc),
        bounds: boundsOf(acc),
        path,
    }
}

function isInteresting(n) {
    return !!(n.id || n.text || n.actions.length || INTERACTIVE_ROLES.has(n.type))
}

// ── tree walk ──────────────────────────────────────────────────────────────────

function walk(acc, windowLabel, path, depth, out, startTime) {
    if (out.length >= MAX_NODES) return
    if (depth > MAX_DEPTH) return
    if (GLib.get_monotonic_time() / 1000 - startTime > DEADLINE_MS) return
    // Only what's actually on screen — skips collapsed/offscreen subtrees, the
    // a11y analogue of UITree's get_mapped() guard.
    if (!isShowing(acc)) return

    const node = nodeOf(acc, windowLabel, path)
    if (isInteresting(node)) out.push(node)

    const tag = node.type + (node.id ? `#${node.id}` : "")
    const childPath = path ? `${path} > ${tag}` : tag

    const count = safe(() => acc.get_child_count(), 0)
    for (let i = 0; i < count; i++) {
        const child = safe(() => acc.get_child_at_index(i), null)
        if (child) walk(child, windowLabel, childPath, depth + 1, out, startTime)
    }
}

// ── target selection ───────────────────────────────────────────────────────────
// Returns [{ frame, label }] — the top-level window(s) to walk. With an arg:
// every window of apps whose name matches the substring. Without: the focused
// window — resolved by correlating with Hyprland's active window (the reliable
// signal; AT-SPI's own STATE_ACTIVE is absent for apps that don't participate),
// falling back to STATE_ACTIVE if hyprctl is unavailable.

function children(acc) {
    const count = safe(() => acc.get_child_count(), 0)
    const out = []
    for (let i = 0; i < count; i++) {
        const c = safe(() => acc.get_child_at_index(i), null)
        if (c) out.push(c)
    }
    return out
}

// Hyprland's focused window class (lowercased), e.g. "org.gnome.nautilus".
function hyprActiveClass() {
    try {
        const [ok, out] = GLib.spawn_command_line_sync("hyprctl activewindow -j")
        if (!ok) return null
        const j = JSON.parse(new TextDecoder().decode(out))
        const cls = (j.class || "").toLowerCase()
        return cls || null
    } catch {
        return null
    }
}

// Tolerant match between an AT-SPI app name and a Hyprland class — they rarely
// match verbatim ("Files"/"nautilus" vs "org.gnome.Nautilus").
function classMatches(appName, cls) {
    appName = (appName || "").toLowerCase()
    if (!appName || !cls) return false
    if (cls.includes(appName) || appName.includes(cls)) return true
    const tail = cls.split(".").pop()
    return !!tail && (appName.includes(tail) || tail.includes(appName))
}

function selectTargets(filter) {
    const desktop = safe(() => Atspi.get_desktop(0), null)
    if (!desktop) return { targets: [], apps: [] }

    const activeClass = filter ? null : hyprActiveClass()
    const targets = []
    const apps = []
    for (const app of children(desktop)) {
        const appName = safe(() => app.get_name(), "") || "?"
        apps.push(appName)
        for (const win of children(app)) {
            const winName = safe(() => win.get_name(), "")
            const label = winName ? `${appName} — ${winName}` : appName
            const match = filter
                ? appName.toLowerCase().includes(filter)
                : activeClass
                    ? classMatches(appName, activeClass)
                    : isActive(win)
            if (match) targets.push({ frame: win, label })
        }
    }
    return { targets, apps, activeClass }
}

// ── main ───────────────────────────────────────────────────────────────────────

function main() {
    if (!computerUseEnabled()) {
        emit({ error: "computer-use is disabled — enable it in Settings → AI (or set allowComputerUse in ai.json)" })
        return
    }

    const filter = (ARGV[0] ?? "").trim().toLowerCase() || null

    Atspi.init() // returns 0 on first success, 1 if already initialised — both fine

    const { targets, apps, activeClass } = selectTargets(filter)
    if (!targets.length) {
        emit({
            source: "atspi",
            app: filter,
            count: 0,
            nodes: [],
            hint: filter
                ? `no window matched "${filter}"`
                : activeClass
                    ? `the focused window (${activeClass}) exposes no accessibility tree — pass an app name to target another window (e.g. crystal-a11y firefox)`
                    : "could not resolve the focused window — pass an app name (e.g. crystal-a11y firefox)",
            apps,
        })
        return
    }

    const out = []
    const startTime = GLib.get_monotonic_time() / 1000
    for (const { frame, label } of targets)
        walk(frame, label, "", 0, out, startTime)

    const result = {
        source: "atspi",
        app: filter,
        count: out.length,
        nodes: out.slice(0, MAX_NODES),
    }
    // A near-empty tree on a real window usually means the app didn't expose
    // accessibility — surface it instead of silently returning nothing.
    if (out.length === 0)
        result.hint = "the target window exposed no accessible nodes — its toolkit may need accessibility enabled (e.g. QT_ACCESSIBILITY=1, Electron --force-renderer-accessibility)"

    emit(result)
}

main()
