#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# nidara-update — update an installed Nidara. Installed to /usr/bin/nidara-update.
#
# Three paths:
#   DEV     — if a dev install registered its own clone (~/.config/nidara/.dev,
#             written by `install.sh --dev`), update from THERE, following the dev
#             branch. Hands over to that clone's install.sh so the updater itself
#             updates with the repo.
#   PACKAGE — nidara is installed as the pacman package (system installs since
#             the packaging switch): new releases arrive through the [nidara]
#             repo on a plain full upgrade, pacman owns files and deps, no git
#             involved. nidara-setup then re-applies the idempotent system/user
#             setup (new config seeds, greetd refresh, new services).
#   STABLE (script-era) — STATELESS: there is NO persistent source copy on disk.
#             Resolve the newest release tag on the remote, shallow-clone just
#             that tag into a throwaway temp dir, install from there, delete it.
#             Running this once on a pre-package install MIGRATES it to the
#             package: the clone's install.sh installs nidara as a package (§6),
#             so the next update takes the PACKAGE path above.
# ─────────────────────────────────────────────────────────────────────────────
set -e

REPO_URL="https://github.com/nidara-project/nidara-desktop.git"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nidara"

# ── DEV path: update from the developer's own registered clone ─────────────────
if [ -f "$CONFIG_DIR/.dev" ]; then
    DEV_SRC="$(cat "$CONFIG_DIR/.dev" 2>/dev/null)"
    if [ -n "$DEV_SRC" ] && [ -f "$DEV_SRC/install.sh" ]; then
        exec bash "$DEV_SRC/install.sh" --update
    fi
    echo "nidara-update: dev marker present but '$DEV_SRC' has no install.sh." >&2
    echo "Re-run ./install.sh --dev from your clone to re-register it." >&2
    exit 1
fi

# ── Carried local patches: refuse to blindly reinstall over them ──────────────
# An agent that keeps a local (not-contributed) repo fix for this user records
# the clone carrying it in .patches — see the in-repo nidara skill,
# references/agent-contribution.md ("Carrying a GLOBAL fix locally"). The
# stateless update below installs pure upstream, which would silently stop
# applying those patches.
if [ -f "$CONFIG_DIR/.patches" ]; then
    PATCH_SRC="$(cat "$CONFIG_DIR/.patches" 2>/dev/null)"
    echo "nidara-update: this install carries local patches (clone: ${PATCH_SRC:-unknown})." >&2
    echo "A plain update would reinstall pure upstream and silently drop them." >&2
    echo "Ask your agent to update instead — it rebases the patches onto the new release" >&2
    echo "and reinstalls (procedure in the repo's nidara skill). To discard the patches" >&2
    echo "and return to pure upstream:" >&2
    echo "    rm ~/.config/nidara/.patches && nidara-update" >&2
    exit 1
fi

# ── PACKAGE path: installed via pacman → update via pacman ───────────────────
# NOTE this must stay AFTER the .patches guard: a patched install is a locally
# built package, and a blind -Syu would replace it with pure upstream the
# moment the repo serves a newer release — silently dropping the patches.
if pacman -Qq nidara >/dev/null 2>&1; then
    old_v="$(pacman -Q nidara | awk '{print $2}')"
    echo "nidara-update: nidara is pacman-managed ($old_v) — running a full system upgrade…"
    # Interactive on purpose (no --noconfirm): this is a FULL system upgrade,
    # the user should see what it pulls in. Declining aborts the update.
    sudo pacman -Syu
    new_v="$(pacman -Q nidara | awk '{print $2}')"
    nidara-setup
    if [ "$old_v" = "$new_v" ]; then
        echo "nidara-update: nidara already up to date ($new_v)."
    else
        echo "nidara-update: nidara $old_v → $new_v."
        # Reload the running shell so the new bundle takes effect now; greeter
        # and lockscreen pick theirs up on next use.
        if systemctl --user is-active --quiet nidara.service 2>/dev/null; then
            systemctl --user restart nidara.service || true
            echo "nidara-update: shell reloaded."
        fi
        # The upgrade replaced /usr/share/nidara/config/hypr/hyprland.lua under
        # the live compositor: Hyprland's config watch fires mid-extract, errors
        # "cannot open … hyprland.lua", and the banner sticks — the watch died
        # with the old inode, so it never sees the new file land. Reload now
        # that it's in place. No-op outside a Hyprland session.
        if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
            hyprctl reload >/dev/null 2>&1 || true
        fi
    fi
    exit 0
fi

# ── STABLE path: stateless update from the remote ─────────────────────────────
command -v git >/dev/null || { echo "nidara-update: git is required." >&2; exit 1; }

# Migrate away from the legacy per-user source copy this model replaces. Safe on
# the stable channel: it keeps no persistent source.
rm -rf "$HOME/.local/share/nidara/src" 2>/dev/null || true
rm -f "$CONFIG_DIR/.source" 2>/dev/null || true

# Newest release tag (the stable channel), resolved without cloning. Empty before
# the first release exists → fall back to the default-branch tip.
latest_tag="$(git ls-remote --tags --refs "$REPO_URL" 'v*' 2>/dev/null \
    | sed 's#.*/##' | sort -V | tail -1)"

# Throwaway checkout on disk (NOT /tmp: a shallow clone + npm build on tmpfs would
# hammer RAM). Removed on exit, success or failure.
mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}/nidara"
work="$(mktemp -d "${XDG_CACHE_HOME:-$HOME/.cache}/nidara/update.XXXXXX")"
trap 'rm -rf "$work"' EXIT

if [ -n "$latest_tag" ]; then
    echo "nidara-update: fetching release $latest_tag …"
    git clone --quiet --depth 1 --branch "$latest_tag" "$REPO_URL" "$work"
else
    echo "nidara-update: no release tags yet — fetching the latest commit …"
    git clone --quiet --depth 1 "$REPO_URL" "$work"
fi

# Build + install from the throwaway clone. --update-apply behaves like a system
# install but skips the Astal/AGS rebuild when the pins are unchanged and writes
# NO source marker; install.sh elevates with sudo internally. No exec — let the
# EXIT trap clean up the temp dir afterwards.
bash "$work/install.sh" --update-apply
