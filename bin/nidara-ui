#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# nidara-ui — Nidara UI launcher
# Installed to /usr/bin/nidara-ui
# Run as ExecStart of nidara.service (auto-respawns on crash). The startup
# exec and SUPER+SHIFT+R go through `systemctl --user start/restart` of that unit.
# ─────────────────────────────────────────────────────────────────────────────

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nidara"
SYS_BUNDLE="/usr/share/nidara/ui/shell/build/nidara"
# Per-user log path: a fixed /tmp file collides on multi-user systems (the
# second user can't append to the first user's file, and a failed redirect
# makes bash skip the exec entirely — the UI would silently never launch).
LOG="${XDG_RUNTIME_DIR:-/tmp}/nidara-ui.log"

# Kill any existing instance cleanly — but ONLY when run standalone. Under the
# systemd unit, systemd already kills the old process's cgroup on restart, and a
# blind `killall -9 gjs` here would also nuke unrelated gjs apps and fight
# systemd's lifecycle. INVOCATION_ID is set only when systemd runs us.
if [ -z "$INVOCATION_ID" ]; then
    killall -9 gjs 2>/dev/null || true
    sleep 0.2
fi

export GDK_BACKEND=wayland
export GI_TYPELIB_PATH="/usr/lib/girepository-1.0:/usr/local/lib/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"
export LD_LIBRARY_PATH="/usr/lib:/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# Flatpak/Snap app visibility. This MUST happen here, before gjs starts: GLib
# caches the data dirs on first use (GTK init), so patching the env from inside
# the shell (AppService.patchXdgDataDirs) is too late for Gio.AppInfo discovery.
# Missing dirs are harmless — gio skips them — so add unconditionally; installing
# flatpak later only needs a shell reload (Super+Shift+R), not an edit here.
XDG_DATA_DIRS="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
for share in /var/lib/flatpak/exports/share "$HOME/.local/share/flatpak/exports/share" /var/lib/snapd/desktop; do
    case ":$XDG_DATA_DIRS:" in *":$share:"*) ;; *) XDG_DATA_DIRS="$XDG_DATA_DIRS:$share" ;; esac
done
export XDG_DATA_DIRS

# ── Dev mode ─────────────────────────────────────────────────────────────────
# If ~/.config/nidara/.dev exists and contains a source path, run from source.
# This file is created by: install.sh --dev
DEV_FILE="$CONFIG_DIR/.dev"
if [ -f "$DEV_FILE" ]; then
    SOURCE_DIR="$(cat "$DEV_FILE")"
    APP_TS="$SOURCE_DIR/ui/shell/app.ts"
    if [ -f "$APP_TS" ]; then
        echo "[$(date '+%H:%M:%S')] nidara-ui: DEV mode — $SOURCE_DIR" | tee -a "$LOG"
        # Asset root for the shell (core/Paths.ts). We start in ui/shell so `ags run`
        # bundles, but the process then chdirs to $HOME so launched apps open there;
        # assets resolve against this fixed root, not the live CWD.
        export NIDARA_SHELL_ROOT="$SOURCE_DIR/ui/shell"
        cd "$SOURCE_DIR/ui/shell"
        # Widget auto-registration: regenerate widgets.gen.ts so a freshly added
        # widget file is picked up by Super+Shift+R. Fail-SOFT on purpose — a
        # hard failure here would brick the reload path; the committed .gen.ts
        # is a stale-but-working fallback and CI is the hard gate.
        if command -v node >/dev/null 2>&1; then
            node "$SOURCE_DIR/scripts/gen-widget-index.mjs" >> "$LOG" 2>&1 \
                || echo "[$(date '+%H:%M:%S')] nidara-ui: WARN — widget codegen failed, running with committed widgets.gen.ts" | tee -a "$LOG"
        fi
        exec ags run app.ts >> "$LOG" 2>&1
    else
        echo "[$(date '+%H:%M:%S')] nidara-ui: WARNING — .dev points to '$SOURCE_DIR' but app.ts not found" | tee -a "$LOG"
    fi
fi

# ── Production mode ───────────────────────────────────────────────────────────
if [ -x "$SYS_BUNDLE" ]; then
    echo "[$(date '+%H:%M:%S')] nidara-ui: bundle $SYS_BUNDLE" >> "$LOG"
    export NIDARA_SHELL_ROOT="/usr/share/nidara/ui/shell"
    cd /usr/share/nidara/ui/shell
    exec "$SYS_BUNDLE" >> "$LOG" 2>&1
fi

echo "[$(date '+%H:%M:%S')] nidara-ui: ERROR — no bundle found at $SYS_BUNDLE" | tee -a "$LOG"
exit 1
