#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# crystal-shell-ui — Crystal Shell UI launcher
# Installed to /usr/bin/crystal-shell-ui
# Run as ExecStart of crystal-shell.service (auto-respawns on crash). The startup
# exec and SUPER+SHIFT+R go through `systemctl --user start/restart` of that unit.
# ─────────────────────────────────────────────────────────────────────────────

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/crystal-shell"
SYS_BUNDLE="/usr/share/crystal-shell/ui/shell/build/crystal-shell"
LOG="/tmp/crystal-shell-ui.log"

# Kill any existing instance cleanly — but ONLY when run standalone. Under the
# systemd unit, systemd already kills the old process's cgroup on restart, and a
# blind `killall -9 gjs` here would also nuke unrelated gjs apps and fight
# systemd's lifecycle. INVOCATION_ID is set only when systemd runs us.
if [ -z "$INVOCATION_ID" ]; then
    killall -9 gjs 2>/dev/null || true
    sleep 0.2
fi

export GDK_BACKEND=wayland
export GI_TYPELIB_PATH="/usr/lib/girepository-1.0:/usr/local/lib/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"
export LD_LIBRARY_PATH="/usr/lib:/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

# ── Dev mode ─────────────────────────────────────────────────────────────────
# If ~/.config/crystal-shell/.dev exists and contains a source path, run from source.
# This file is created by: install.sh --dev
DEV_FILE="$CONFIG_DIR/.dev"
if [ -f "$DEV_FILE" ]; then
    SOURCE_DIR="$(cat "$DEV_FILE")"
    APP_TS="$SOURCE_DIR/ui/shell/app.ts"
    if [ -f "$APP_TS" ]; then
        echo "[$(date '+%H:%M:%S')] crystal-shell-ui: DEV mode — $SOURCE_DIR" | tee -a "$LOG"
        # Asset root for the shell (core/Paths.ts). We start in ui/shell so `ags run`
        # bundles, but the process then chdirs to $HOME so launched apps open there;
        # assets resolve against this fixed root, not the live CWD.
        export CRYSTAL_SHELL_ROOT="$SOURCE_DIR/ui/shell"
        cd "$SOURCE_DIR/ui/shell"
        exec ags run app.ts >> "$LOG" 2>&1
    else
        echo "[$(date '+%H:%M:%S')] crystal-shell-ui: WARNING — .dev points to '$SOURCE_DIR' but app.ts not found" | tee -a "$LOG"
    fi
fi

# ── Production mode ───────────────────────────────────────────────────────────
if [ -x "$SYS_BUNDLE" ]; then
    echo "[$(date '+%H:%M:%S')] crystal-shell-ui: bundle $SYS_BUNDLE" >> "$LOG"
    export CRYSTAL_SHELL_ROOT="/usr/share/crystal-shell/ui/shell"
    cd /usr/share/crystal-shell/ui/shell
    exec "$SYS_BUNDLE" >> "$LOG" 2>&1
fi

echo "[$(date '+%H:%M:%S')] crystal-shell-ui: ERROR — no bundle found at $SYS_BUNDLE" | tee -a "$LOG"
exit 1
