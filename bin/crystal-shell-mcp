#!/usr/bin/env -S gjs -m
// ─────────────────────────────────────────────────────────────────────────────
// crystal-shell-mcp — MCP (Model Context Protocol) server for Crystal Shell
// Installed to /usr/bin/crystal-shell-mcp. Speaks MCP over stdio (newline-
// delimited JSON-RPC 2.0); register it in an MCP client (Claude Code, etc.):
//
//   { "mcpServers": { "crystal-shell": { "command": "crystal-shell-mcp" } } }
//
// WHY THIS EXISTS: the shell already exposes a complete agent surface over
// `ags request` (listActions/dumpState/describeConfig/setConfig/screenshot)
// plus `crystal-shell-doctor`. This server is a thin adapter that turns that
// surface into typed MCP tools so any MCP client gets it for free — no shell
// parsing, and screenshots come back as inline images the client can see.
// It deliberately contains NO logic of its own: every tool delegates to the
// running shell, so the IPC table in app.ts stays the single source of truth.
//
// Plain GJS on purpose (same pattern as crystal-portal): no Node runtime and
// no npm deps on installed systems — gjs ships with the shell. The MCP subset
// implemented (initialize / tools/list / tools/call / ping) is the stable
// core of the protocol.
//
// Governance: Settings → AI. `ai.json.allowMcp` is re-read on every call, so
// flipping the toggle takes effect live (off = every tool refuses). The
// finer gates (allowConfigWrite, allowScreenshot) are enforced downstream by
// the shell itself — this is a consent layer, not a security boundary.
// ─────────────────────────────────────────────────────────────────────────────

import GLib from "gi://GLib"
import Gio from "gi://Gio"
import GioUnix from "gi://GioUnix"

const PROTOCOL_VERSION = "2025-06-18"
const AI_JSON = `${GLib.get_user_config_dir()}/crystal-shell/ai.json`

// Dev-checkout pointer written by `install.sh --dev` (absent on system installs).
function devRepo() {
    try {
        const dev = `${GLib.get_user_config_dir()}/crystal-shell/.dev`
        if (GLib.file_test(dev, GLib.FileTest.EXISTS)) return textFile(dev).trim()
    } catch {}
    return null
}

function shellVersion() {
    try {
        const repo = devRepo()
        if (repo) return textFile(`${repo}/VERSION`).trim() || "dev"
        return textFile("/usr/share/crystal-shell/VERSION").trim() || "?"
    } catch {
        return "?"
    }
}

// PATH first, dev checkout second — a dev machine may not have re-run
// install.sh since a binary was added.
function findTool(name) {
    const inPath = GLib.find_program_in_path(name)
    if (inPath) return inPath
    const repo = devRepo()
    if (repo && GLib.file_test(`${repo}/bin/${name}`, GLib.FileTest.IS_EXECUTABLE))
        return `${repo}/bin/${name}`
    return null
}

function textFile(path) {
    const [ok, bytes] = GLib.file_get_contents(path)
    if (!ok) throw new Error(`cannot read ${path}`)
    return new TextDecoder().decode(bytes)
}

function mcpEnabled() {
    try {
        if (!GLib.file_test(AI_JSON, GLib.FileTest.EXISTS)) return true
        const cfg = JSON.parse(textFile(AI_JSON))
        return cfg.allowMcp !== false
    } catch {
        return true
    }
}

// Run a command synchronously, capturing stdout+stderr. The server handles
// one request at a time, so blocking here is fine (and keeps ordering).
function run(argv) {
    const proc = Gio.Subprocess.new(
        argv,
        Gio.SubprocessFlags.STDOUT_PIPE | Gio.SubprocessFlags.STDERR_PIPE,
    )
    const [, out, err] = proc.communicate_utf8(null, null)
    return { ok: proc.get_successful(), out: (out ?? "").trim(), err: (err ?? "").trim() }
}

function agsRequest(args) {
    const r = run(["ags", "request", ...args])
    if (!r.ok && !r.out)
        throw new Error(
            `ags request failed (is the shell running?): ${r.err || "no output"}`,
        )
    return r.out
}

const text = (s) => [{ type: "text", text: s }]
const okResult = (s) => ({ content: text(s) })
const errResult = (s) => ({ content: text(s), isError: true })

// ── Tools ────────────────────────────────────────────────────────────────────
// Descriptions are the agent-facing documentation — keep them honest and
// aligned with the IPC descriptions served by `listActions`.

const TOOLS = [
    {
        name: "list_actions",
        description:
            "List every IPC action the running Crystal Shell exposes (name, description, aliases) as JSON. Call this before run_action — never guess action names.",
        inputSchema: { type: "object", properties: {}, additionalProperties: false },
        handler: () => okResult(agsRequest(["listActions"])),
    },
    {
        name: "run_action",
        description:
            "Run a Crystal Shell IPC action by name (e.g. toggleCC, settingsPage bluetooth). Discover names with list_actions. Equivalent to `ags request <name> [args…]`.",
        inputSchema: {
            type: "object",
            properties: {
                name: { type: "string", description: "Action name from list_actions" },
                args: {
                    type: "array",
                    items: { type: "string" },
                    description: "Positional arguments, if the action takes any",
                },
            },
            required: ["name"],
            additionalProperties: false,
        },
        handler: ({ name, args = [] }) => okResult(agsRequest([name, ...args])),
    },
    {
        name: "dump_state",
        description:
            "Live shell state as JSON: version, locale, dark mode, monitors, open overlays, effective Hyprland config (gaps/rounding/border incl. user overrides) and AI-governance flags. Read state → act → re-read to verify.",
        inputSchema: { type: "object", properties: {}, additionalProperties: false },
        handler: () => okResult(agsRequest(["dumpState"])),
    },
    {
        name: "describe_config",
        description:
            "Schema of every agent-exposed shell setting: description, type, enum/min/max, writability and current value. Call this before get_config/set_config — never guess keys.",
        inputSchema: { type: "object", properties: {}, additionalProperties: false },
        handler: () => okResult(agsRequest(["describeConfig"])),
    },
    {
        name: "get_config",
        description:
            "Read shell settings: one value if `key` is given (e.g. dock.iconSize), all values otherwise.",
        inputSchema: {
            type: "object",
            properties: {
                key: { type: "string", description: "Setting key from describe_config" },
            },
            additionalProperties: false,
        },
        handler: ({ key }) => okResult(agsRequest(key ? ["getConfig", key] : ["getConfig"])),
    },
    {
        name: "set_config",
        description:
            "Change a shell setting through the official validated door (persists and updates the UI like Settings would). Gated by Settings → AI → Allow Agents to Change Settings. Values are passed as strings (e.g. \"blue\", \"48\", \"true\").",
        inputSchema: {
            type: "object",
            properties: {
                key: { type: "string", description: "Setting key from describe_config" },
                value: { type: "string", description: "New value, as a string" },
            },
            required: ["key", "value"],
            additionalProperties: false,
        },
        handler: ({ key, value }) => okResult(agsRequest(["setConfig", key, value])),
    },
    {
        name: "screenshot",
        description:
            "Capture the focused monitor and return the image inline — the visual-verification leg of the agent loop (open a surface, wait ~1.5 s, screenshot). Gated by Settings → AI → Allow Agents to Capture the Screen.",
        inputSchema: {
            type: "object",
            properties: {
                path: { type: "string", description: "Optional PNG output path" },
            },
            additionalProperties: false,
        },
        handler: ({ path }) => {
            const out = agsRequest(path ? ["screenshot", path] : ["screenshot"])
            // On success the IPC returns the PNG path; anything else is the
            // shell explaining why it refused (gate off, grim missing…).
            if (!out.endsWith(".png") || !GLib.file_test(out, GLib.FileTest.EXISTS))
                return errResult(out)
            const [ok, bytes] = GLib.file_get_contents(out)
            if (!ok) return errResult(`could not read screenshot at ${out}`)
            return {
                content: [
                    { type: "image", data: GLib.base64_encode(bytes), mimeType: "image/png" },
                    { type: "text", text: out },
                ],
            }
        },
    },
    {
        name: "doctor",
        description:
            "Full diagnostic report (Markdown) from crystal-shell-doctor: versions, hardware, monitors, service status, live state, idle wakeups, recent log errors. Run this FIRST when something misbehaves; attach it as evidence in issues/PRs.",
        inputSchema: { type: "object", properties: {}, additionalProperties: false },
        handler: () => {
            const doctor = findTool("crystal-shell-doctor")
            if (!doctor) return errResult("crystal-shell-doctor not found — re-run install.sh")
            const r = run([doctor])
            return r.out ? okResult(r.out) : errResult(`doctor failed: ${r.err}`)
        },
    },
]

// ── JSON-RPC over stdio ──────────────────────────────────────────────────────

const stdout = new Gio.DataOutputStream({
    base_stream: new GioUnix.OutputStream({ fd: 1, close_fd: false }),
})

function send(msg) {
    stdout.put_string(JSON.stringify(msg) + "\n", null)
    stdout.flush(null)
}

const reply = (id, result) => send({ jsonrpc: "2.0", id, result })
const replyError = (id, code, message) =>
    send({ jsonrpc: "2.0", id, error: { code, message } })

function handle(msg) {
    const { id, method, params } = msg

    switch (method) {
        case "initialize":
            return reply(id, {
                protocolVersion: params?.protocolVersion ?? PROTOCOL_VERSION,
                capabilities: { tools: {} },
                serverInfo: { name: "crystal-shell", version: shellVersion() },
            })
        case "ping":
            return reply(id, {})
        case "tools/list":
            return reply(id, {
                tools: TOOLS.map(({ name, description, inputSchema }) => ({
                    name,
                    description,
                    inputSchema,
                })),
            })
        case "tools/call": {
            const tool = TOOLS.find((t) => t.name === params?.name)
            if (!tool) return replyError(id, -32602, `unknown tool: ${params?.name}`)
            if (!mcpEnabled())
                return reply(id, errResult(
                    "MCP access is disabled — enable it in Settings → AI (or set allowMcp in ai.json)",
                ))
            try {
                return reply(id, tool.handler(params?.arguments ?? {}))
            } catch (e) {
                return reply(id, errResult(String(e?.message ?? e)))
            }
        }
        default:
            // Notifications (initialized, cancelled…) need no response.
            if (id === undefined || id === null) return
            return replyError(id, -32601, `method not found: ${method}`)
    }
}

const loop = new GLib.MainLoop(null, false)
const stdin = new Gio.DataInputStream({
    base_stream: new GioUnix.InputStream({ fd: 0, close_fd: false }),
})

function readLoop() {
    stdin.read_line_async(GLib.PRIORITY_DEFAULT, null, (src, res) => {
        let line
        try {
            ;[line] = src.read_line_finish_utf8(res)
        } catch {
            return loop.quit()
        }
        if (line === null) return loop.quit() // client closed stdin → exit
        if (line.trim()) {
            try {
                handle(JSON.parse(line))
            } catch {
                send({
                    jsonrpc: "2.0",
                    id: null,
                    error: { code: -32700, message: "parse error" },
                })
            }
        }
        readLoop()
    })
}

readLoop()
loop.run()
