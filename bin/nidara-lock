#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# nidara-lock — Nidara lock screen launcher
# Installed to /usr/bin/nidara-lock
# Called by hypridle, loginctl lock-session, and Hyprland keybinds
# ─────────────────────────────────────────────────────────────────────────────

BUNDLE="/usr/share/nidara/ui/lockscreen/build/nidara-lock"
# /tmp like every other nidara-* log. /var/log is not user-writable: the
# `>> $LOG` redirect fails and bash then skips launching the bundle entirely,
# so the screen silently never locks (bit us 2026-07-03).
LOG="/tmp/nidara-lock.log"

export GDK_BACKEND=wayland
export GI_TYPELIB_PATH="/usr/lib/girepository-1.0:/usr/local/lib/girepository-1.0${GI_TYPELIB_PATH:+:$GI_TYPELIB_PATH}"
export LD_LIBRARY_PATH="/usr/lib:/usr/local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export LD_PRELOAD="/usr/lib/libgtk4-layer-shell.so${LD_PRELOAD:+:$LD_PRELOAD}"

# Prevent multiple instances (exclude own PID — bash names itself after the script)
SELF=$$
if pgrep -x nidara-lock | grep -qv "^${SELF}$"; then
    exit 0
fi

if [ ! -x "$BUNDLE" ]; then
    echo "[$(date '+%H:%M:%S')] nidara-lock: ERROR — bundle not found at $BUNDLE" | tee -a "$LOG"
    exit 1
fi

# Hide bar and dock, disable all keybinds
# (workspace switch not needed — ext-session-lock-v1 covers all monitors at compositor level)
ags request hideForLock >> "$LOG" 2>&1 || true
hyprctl dispatch 'hl.dsp.submap("lock")' >> "$LOG" 2>&1 || true

# Run lockscreen — blocks until app.quit() on successful auth.
# Watchdog: if the bundle dies abnormally (e.g. GTK4 segfault when a wl_output
# vanishes on wake — seen 2026-06-10), relaunch it. misc.allow_session_lock_restore
# lets the new instance take over the lock instead of leaving Hyprland's red
# "lock app crashed" screen.
cd /usr/share/nidara/ui/lockscreen
attempts=0
while true; do
    "$BUNDLE" >> "$LOG" 2>&1
    code=$?
    [ "$code" -eq 0 ] && break
    attempts=$((attempts + 1))
    if [ "$attempts" -ge 5 ]; then
        echo "[$(date '+%H:%M:%S')] nidara-lock: bundle crashed $attempts times (last exit $code) — giving up" | tee -a "$LOG"
        break
    fi
    echo "[$(date '+%H:%M:%S')] nidara-lock: bundle exited $code — relaunching ($attempts/5)" >> "$LOG"
    sleep 1
done

# Restore everything after unlock
hyprctl dispatch 'hl.dsp.submap("reset")' >> "$LOG" 2>&1 || true
ags request showAfterLock >> "$LOG" 2>&1 || true
