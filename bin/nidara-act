#!/usr/bin/env -S gjs -m
// ─────────────────────────────────────────────────────────────────────────────
// nidara-act — DETERMINISTIC action on third-party apps for the computer-use
// layer (Phase 2a). Installed to /usr/bin/nidara-act. Invokes a NAMED AT-SPI
// action on a NAMED accessible — the deterministic interaction hook, same
// philosophy as the shell's own `openWindowMenu` ("without a synthetic click").
// NO coordinates, NO synthetic input: it targets the accessible directly, so it
// is auditable and not focus-dependent (unlike a blind click at a position).
//
//   nidara-act <app> <node-name> <action> [role] [occurrence]
//   e.g.  nidara-act nautilus "Name" view.show-hidden-files
//         nidara-act telegram "Buscar mensajes" SetFocus button
//
// The agent perceives a node (its name + available action names) with
// `nidara-a11y`/`query_app`, then acts on it here by name. Coverage matches
// perception: GTK4 exposes rich activatable actions (incl. its GActions); Qt
// often exposes only SetFocus (focus yes, click no — clicking Qt waits for the
// synthetic-input phase 2b).
//
// SEPARATE binary from nidara-a11y on purpose: perception stays read-only, and
// action is a distinct, separately-gated capability (the maintainer guardian
// rule — do_action must never be smuggled into the perception helper).
//
// Plain GJS (gi://Atspi), same no-Node pattern as nidara-a11y/nidara-portal.
//
// Governance: BOTH `allowComputerControl` AND `allowComputerUse` must be true in
// ai.json (Settings → AI). Control requires perception; both default OFF.
// Consent layer, not a security boundary — any local process can already drive
// the a11y bus. The shell renders an always-visible indicator + kill switch
// while control is granted.
// ─────────────────────────────────────────────────────────────────────────────

import Atspi from "gi://Atspi"
import GLib from "gi://GLib"

const AI_JSON = `${GLib.get_user_config_dir()}/nidara/ai.json`
const MAX_NODES = 4000   // a match scan can touch more nodes than a perception cap
const MAX_DEPTH = 40

function emit(obj) { print(JSON.stringify(obj, null, 2)) }

// Fire-and-forget: tell the shell an action just landed so the bar's AI-control
// indicator shows its "active" pulse (decays back to "armed" after a few seconds).
// Never blocks or fails the action if the shell isn't reachable.
function pingShell() {
    try { GLib.spawn_command_line_async("ags request notifyComputerAction") } catch {}
}

function safe(fn, fallback) {
    try { const v = fn(); return v == null ? fallback : v } catch { return fallback }
}

// Both gates required; both default OFF (absent/garbled ai.json → disabled).
function controlEnabled() {
    try {
        if (!GLib.file_test(AI_JSON, GLib.FileTest.EXISTS)) return false
        const [ok, bytes] = GLib.file_get_contents(AI_JSON)
        if (!ok) return false
        const cfg = JSON.parse(new TextDecoder().decode(bytes))
        return cfg.allowComputerControl === true && cfg.allowComputerUse === true
    } catch {
        return false
    }
}

function children(acc) {
    const count = safe(() => acc.get_child_count(), 0)
    const out = []
    for (let i = 0; i < count; i++) {
        const c = safe(() => acc.get_child_at_index(i), null)
        if (c) out.push(c)
    }
    return out
}

function isShowing(acc) {
    const set = safe(() => acc.get_state_set(), null)
    return !!set && safe(() => set.contains(Atspi.StateType.SHOWING), false)
}

function nameOf(acc) { return safe(() => acc.get_name(), "") || "" }
function roleOf(acc) { return safe(() => acc.get_role_name(), "?") }

function boundsOf(acc) {
    const iface = safe(() => acc.get_component_iface(), null)
    if (!iface) return { w: 0, h: 0 }
    const r = safe(() => iface.get_extents(Atspi.CoordType.WINDOW), null)
    if (!r) return { w: 0, h: 0 }
    return { x: Math.round(r.x), y: Math.round(r.y), w: Math.round(r.width), h: Math.round(r.height) }
}

function actionsOf(acc) {
    const iface = safe(() => acc.get_action_iface(), null)
    if (!iface) return { iface: null, names: [] }
    const n = safe(() => iface.get_n_actions(), 0)
    const names = []
    for (let i = 0; i < n; i++) names.push(safe(() => iface.get_action_name(i), ""))
    return { iface, names }
}

// Tolerant app match: AT-SPI app name vs the user-supplied filter (substring).
function appMatches(appName, filter) {
    return appName.toLowerCase().includes(filter)
}

// Collect every showing node in the target app(s) whose name matches `nodeName`
// (case-insensitive exact, then substring) and, if given, whose role matches.
function findMatches(filter, nodeName, roleFilter) {
    const desktop = safe(() => Atspi.get_desktop(0), null)
    if (!desktop) return { matches: [], apps: [] }

    const want = nodeName.toLowerCase()
    const exact = []
    const partial = []
    const apps = []
    let scanned = 0

    const visit = (acc, depth) => {
        if (scanned >= MAX_NODES || depth > MAX_DEPTH) return
        if (!isShowing(acc)) return
        scanned++
        const nm = nameOf(acc)
        if (nm) {
            const role = roleOf(acc)
            if (!roleFilter || role === roleFilter) {
                const low = nm.toLowerCase()
                if (low === want) exact.push(acc)
                else if (low.includes(want)) partial.push(acc)
            }
        }
        for (const c of children(acc)) visit(c, depth + 1)
    }

    for (const app of children(desktop)) {
        const appName = nameOf(app) || "?"
        apps.push(appName)
        if (!appMatches(appName, filter)) continue
        for (const win of children(app)) visit(win, 0)
    }
    // Prefer exact-name matches; fall back to substring matches.
    return { matches: exact.length ? exact : partial, apps }
}

function describe(acc) {
    return { name: nameOf(acc), role: roleOf(acc), bounds: boundsOf(acc) }
}

function main() {
    if (!controlEnabled()) {
        emit({ error: "computer-control is disabled — enable 'Allow Agents to Control Other Apps' in Settings → AI (it requires perception too; both default off)" })
        return
    }

    const app = (ARGV[0] ?? "").trim()
    const nodeName = (ARGV[1] ?? "").trim()
    const action = (ARGV[2] ?? "").trim()
    const roleFilter = (ARGV[3] ?? "").trim() || null
    const occRaw = (ARGV[4] ?? "").trim()
    const occurrence = occRaw === "" ? null : parseInt(occRaw, 10)

    if (!app || !nodeName || !action) {
        emit({ error: "usage: nidara-act <app> <node-name> <action> [role] [occurrence]" })
        return
    }

    Atspi.init()

    const { matches, apps } = findMatches(app.toLowerCase(), nodeName, roleFilter)
    if (!matches.length) {
        emit({ error: `no showing node named "${nodeName}"${roleFilter ? ` (role ${roleFilter})` : ""} found in app "${app}"`, apps })
        return
    }
    if (matches.length > 1 && occurrence === null) {
        emit({
            error: `ambiguous: ${matches.length} nodes match "${nodeName}" — disambiguate with a role and/or occurrence index`,
            candidates: matches.slice(0, 20).map((m, i) => ({ occurrence: i, ...describe(m) })),
        })
        return
    }

    const target = occurrence !== null ? matches[occurrence] : matches[0]
    if (!target) {
        emit({ error: `occurrence ${occurrence} out of range (${matches.length} matches)` })
        return
    }

    const { iface, names } = actionsOf(target)
    if (!iface) {
        emit({ error: `node "${nodeName}" exposes no AT-SPI actions`, node: describe(target) })
        return
    }
    const idx = names.findIndex(n => n === action)
    if (idx < 0) {
        emit({ error: `action "${action}" not available on this node`, node: describe(target), available: names })
        return
    }

    // The defensive .prototype.call idiom: an AtspiAction is the same boxed
    // object as the Accessible, so call the Action interface method explicitly
    // (same lesson as get_text colliding with Atspi.Accessible.get_text).
    const result = safe(() => Atspi.Action.prototype.do_action.call(iface, idx), false)
    if (result === true) pingShell()

    emit({ ok: result === true, app, node: describe(target), action, result })
}

main()
