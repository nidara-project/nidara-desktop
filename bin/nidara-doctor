#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# nidara-doctor — diagnostic snapshot of a Nidara installation
# Installed to /usr/bin/nidara-doctor
#
# One command that gathers everything needed to diagnose a problem or to attach
# as evidence to a bug report / PR: versions, hardware, compositor state, the
# shell's own live state (via `ags request dumpState`), and recent log errors.
# Output is Markdown — paste it directly into a GitHub issue or PR body.
#
# This is also the agent entry point: an AI agent helping a user should run
# this FIRST when something misbehaves, and include it when proposing a
# hardware/compat fix upstream (see the nidara skill,
# references/agent-contribution.md — evidence IS the test).
#
# Every section degrades gracefully: a missing tool/daemon prints "n/a" instead
# of aborting, so the report is useful even on a half-broken setup.
#
# Usage:  nidara-doctor            # full report to stdout
# ─────────────────────────────────────────────────────────────────────────────
set -uo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nidara"
LOG="${XDG_RUNTIME_DIR:-/tmp}/nidara-ui.log"

# `cmd args…` → run, indent as a code block; print "n/a (reason)" on failure.
section() { printf '\n## %s\n\n' "$1"; }
codeblock() {
    local out
    if out=$("$@" 2>&1) && [ -n "$out" ]; then
        printf '```\n%s\n```\n' "$out"
    else
        printf '_n/a (`%s` failed or empty)_\n' "$*"
    fi
}

echo "# Nidara — diagnostic report ($(date -u '+%Y-%m-%d %H:%M UTC'))"

section "Versions"
{
    ver="?"
    if [ -f "$CONFIG_DIR/.dev" ] && [ -f "$(cat "$CONFIG_DIR/.dev")/VERSION" ]; then
        ver="$(cat "$(cat "$CONFIG_DIR/.dev")/VERSION") (dev checkout: $(cat "$CONFIG_DIR/.dev"))"
    elif [ -f /usr/share/nidara/VERSION ]; then
        ver="$(cat /usr/share/nidara/VERSION) (system install)"
    fi
    echo '```'
    echo "nidara: $ver"
    echo "hyprland:      $(hyprctl version 2>/dev/null | head -1 || echo n/a)"
    echo "ags:           $(ags --version 2>/dev/null || echo n/a)"
    echo "gjs:           $(gjs --version 2>/dev/null || echo n/a)"
    echo "gtk4:          $(pacman -Q gtk4 2>/dev/null || echo n/a)"
    echo "kernel:        $(uname -r)"
    echo "os:            $(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME" || echo n/a)"
    echo '```'
}

section "Hardware"
codeblock sh -c "lspci -nn 2>/dev/null | grep -Ei 'vga|3d|display|network|wireless' ; lscpu 2>/dev/null | grep 'Model name' ; free -h 2>/dev/null | grep Mem"

section "Monitors (hyprctl)"
codeblock sh -c "hyprctl monitors -j 2>/dev/null | head -100"

section "Shell service (systemd --user)"
codeblock systemctl --user --no-pager status nidara

section "Shell live state (ags request dumpState)"
codeblock ags request dumpState

section "Idle wakeups (main thread, 4 s sample — healthy ≈ 0/s when idle)"
{
    SHELL_PID=$(pgrep -f "gjs -m .*/ags.js" | head -1)
    if [ -n "${SHELL_PID:-}" ]; then
        TS="/proc/$SHELL_PID/task/$SHELL_PID/status"
        W1=$(awk '/voluntary/{s+=$2} END{print s}' "$TS" 2>/dev/null)
        sleep 4
        W2=$(awk '/voluntary/{s+=$2} END{print s}' "$TS" 2>/dev/null)
        printf '```\n%s wakeups/s\n```\n' "$(( (W2-W1)/4 ))"
    else
        printf '_n/a (shell process not found)_\n'
    fi
}

section "Recent log errors (last 40 matching lines of $LOG)"
codeblock sh -c "grep -iE 'error|critical|warning|failed|exception' '$LOG' 2>/dev/null | tail -40"

section "Config layer (what exists in $CONFIG_DIR)"
codeblock sh -c "ls -la '$CONFIG_DIR' 2>/dev/null"

echo
echo "_Generated by nidara-doctor. Personal values (wallpaper, pinned apps,"
echo "accent) are not included beyond file names; review before posting publicly._"
