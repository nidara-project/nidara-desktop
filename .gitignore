# Python
__pycache__/
*.py[cod]
*.pyo
.env
venv/

# OS
.DS_Store
*.swp
*~
*.zip

# IDE
.vscode/
.idea/

# Build & Dist (system-level, not app bundle)
*.deb
*.iso
dist/
target/
# App bundles (shell/greeter/lockscreen) — build artifacts, NOT committed.
# Regenerated by `npm run build`; dev runs from source (`ags run`) and
# install.sh --system rebuilds them before copying to /usr/share. Committing
# them only bloated git history (~4MB/commit) for no deploy benefit.
ui/*/build/

# Media & Recordings
*.mkv
*.mp4
*.webm
*.png
*.jpg
*.jpeg
*.gif
*.webp

# Antigravity / Agent
.agent/
.agents/
_agent/
_agents/
.antigravity/
.gemini/
brain/
logs/

# Node
node_modules/
# ui/shell depends on ags/gnim as file: links into /usr/share/ags/js; npm
# records those in the lockfile as paths RELATIVE to the checkout depth, so a
# committed lockfile only works for checkouts at the original machine's depth.
# Don't version it — npm install regenerates it locally.
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temp
*.log
*.tmp
google-chrome-stable_current_amd64.deb

# Local Builds & Deps
aquamarine/
hyprgraphics/
hyprland-protocols/
hyprlang/
hyprpaper/
hyprpicker/
hyprsunset/
hyprsysteminfo/
hyprtoolkit/
hyprutils/
hyprwayland-scanner/
hyprwire/
local/
temp_deps/

# Debug & Temp files
debug_*.js
*_debug.txt
*_json.txt
settings_addr.txt

# User config files — generated at runtime, may appear in repo root
# if install.sh was previously run in legacy symlink dev mode
crystal-settings.conf
crystal-monitor.conf
hyprland-user.conf
crystal-settings.lua
crystal-monitor.lua
hyprland-user.lua

# Generated CSS (kept in repo as pre-compiled convenience for users)
# ui/shell/style.css  ← intentionally NOT ignored
ui/shell/style.css.map
# User configs — generated at runtime, personal to each installation
# (root-level only; defaults/ folder is intentionally tracked)
theme_settings.json
fluid-crystal.json
/appearance.json
/region.json
/cc_layout.json
/widgets.json

# Dev mode marker (written by install.sh --dev, personal to each machine)
.dev

# Agent Memory
MEMORY.md
memory/
AGENTS.md
HEARTBEAT.md

# AI assistant files
CLAUDE.md
# Ignore everything under .claude/ (personal Claude Code state) EXCEPT the skill,
# which ships with the project so any user's agent can extend it and contribute back.
.claude/*
!.claude/skills/

# More runtime user state (root-level, personal to each install)
/bar-settings.json
/gaming.json
/greeter-prefs.json
/night-light.json
/wallpaper

# Hyprglass plugin — embedded repo, intentionally not part of this project
hyprglass/
SOUL.md
USER.md
IDENTITY.md

# Build & External Dependencies
vendor/
plugins/
astal-local/

restore_history.sh
CRYSTAL_SHELL_ARCHITECTURE.md

# Internal docs — for us, not shipped with the project
docs/

# wallpaper directory is tracked (default asset shipped with the project)
!defaults/wallpaper/
!defaults/wallpaper/*.png
